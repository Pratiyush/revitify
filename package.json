{
  "name": "revitify",
  "version": "0.1.0",
  "description": "Revitify — Rivet's native TypeScript code-knowledge-graph engine. Same output contract as graphify (graph.json · graph.html · GRAPH_REPORT.md), zero Python required. Concepts adapted from graphify (MIT, github.com/safishamsi/graphify); original implementation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "bin": {
    "revitify": "./dist/cli/main.js"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome check --write .",
    "knip": "knip",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "check": "pnpm run build && pnpm run lint && pnpm run knip && pnpm run depcruise && pnpm run test:coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "typescript": "^5.5.4",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dependency-cruiser": "^17.4.3",
    "knip": "^6.16.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
