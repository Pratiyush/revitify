{
  "version": 1,
  "project": {
    "name": "untitled",
    "platforms": [
      "typescript"
    ]
  },
  "mode": {
    "routing": "auto-override",
    "confirmFirst": true,
    "researchMode": true,
    "custom": {}
  },
  "intake": {
    "sources": [
      "raw",
      "github"
    ],
    "jiraEpic": "ask",
    "writeBack": false
  },
  "spec": {
    "style": "both",
    "acceptanceCriteria": "tool-drafts",
    "criteriaFormat": "gherkin",
    "breakdownDepth": "feature-story-task-subtask",
    "estimates": true,
    "autoDependencies": true,
    "diagram": true,
    "gapHunting": "propose",
    "riskWarn": true,
    "livingPlan": "update-ask",
    "onVague": "clarify"
  },
  "build": {
    "tests": "tdd",
    "fileFence": false,
    "retryLimit": 3,
    "checkFrequency": "per-task",
    "whenStuck": "bounded-then-ask",
    "codeStyle": "both",
    "reuse": "prefer",
    "comments": "moderate",
    "commitCadence": "per-task",
    "newDeps": "ask-big"
  },
  "verify": {
    "kinds": [
      "unit",
      "integration",
      "api",
      "e2e"
    ],
    "buildAll": [],
    "coverage": null,
    "blockDoneOnFail": true,
    "everyCriterionNeedsCheck": true,
    "runApp": false,
    "ui": "off",
    "sandbox": "local",
    "security": "on-demand",
    "lintTypes": "part-of-done",
    "flaky": "retry-flag",
    "runners": {},
    "kindRunners": {},
    "app": {
      "start": [],
      "readyUrl": null,
      "readyTimeoutMs": 30000
    }
  },
  "review": {
    "separateReviewer": true,
    "angles": [
      "correctness",
      "security",
      "performance",
      "style"
    ],
    "passes": "both",
    "fixFindings": "list"
  },
  "pr": {
    "autoBody": true,
    "branchPattern": "{type}/{slug}",
    "merge": "manual",
    "waitForCI": true,
    "commitAuthor": "user",
    "cleanupAfterMerge": true
  },
  "memory": {
    "crashResume": "exact",
    "journal": "full",
    "driftDetection": true
  },
  "parallel": {
    "enabled": true,
    "waveSize": 6,
    "isolation": "worktree",
    "onFileClash": "serialize",
    "coordinator": true
  },
  "dashboard": {
    "enabled": true,
    "refreshSeconds": 15,
    "form": "web",
    "updates": "live",
    "notify": {
      "channels": [],
      "on": []
    }
  },
  "rules": {
    "laws": true,
    "onConflict": "warn",
    "inheritPersonal": true,
    "requireQualifiedIds": "warn"
  },
  "learning": {
    "capture": true,
    "promoteToRules": "ask",
    "bugToTest": true,
    "scope": "both",
    "retro": "per-feature",
    "warnOnRepeat": true,
    "share": "personal"
  },
  "gates": {
    "facts": "off",
    "negativeFloor": "on",
    "require": [],
    "packs": {
      "security": {
        "sections": [
          "Security"
        ],
        "kinds": [],
        "triggers": [
          "auth",
          "login",
          "password",
          "token",
          "secret",
          "payment",
          "crypt",
          "session",
          "permission",
          "sql"
        ]
      },
      "contracts": {
        "sections": [
          "API Contract"
        ],
        "kinds": [
          "api"
        ],
        "triggers": []
      },
      "nfr": {
        "sections": [
          "NFR"
        ],
        "kinds": [],
        "triggers": []
      },
      "rollback": {
        "sections": [
          "Rollback"
        ],
        "kinds": [],
        "triggers": []
      }
    }
  },
  "graphify": {
    "provider": "revitify",
    "outDir": "graphify-out",
    "freshness": "update-on-run"
  }
}
