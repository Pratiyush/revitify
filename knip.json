{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["test/**/*.test.ts", "test/**/*.test-d.ts", "scripts/*.mjs"],
  "project": ["src/**/*.ts", "test/**/*.ts", "!test/fixtures/**", "scripts/*.mjs"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["which", "scip", "whisper-cli", "whisper-cpp"]
}
